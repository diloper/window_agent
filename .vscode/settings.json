{
    "terminal.integrated.defaultProfile.windows": "PowerShell",
    "terminal.integrated.automationProfile.windows": {
        "path": "powershell.exe"
    },
    "terminal.integrated.env.windows": {
        "CONDA_DEFAULT_ENV": "base",
        "PATH": "R:\\Users\\User\\miniconda3\\Scripts;R:\\Users\\User\\miniconda3;${PATH}"
    },
    "terminal.integrated.profiles.windows": {
        "PowerShell": {
            "path": "powershell.exe",
            "args": [
                "-NoExit",
                "-Command",
                "& \"R:\\Users\\$env:USERNAME\\miniconda3\\Scripts\\conda.exe\" \"shell.powershell\" \"hook\" | Out-String | Invoke-Expression"
            ]
        }
    },
    "editor.formatOnSave": true,
    "editor.codeActionsOnSave": {
        "source.fixAll": "explicit",
        "source.organizeImports": "explicit"
    },
    "files.encoding": "utf8",
    "files.insertFinalNewline": true,
    "files.trimTrailingWhitespace": true,
    "files.exclude": {
        "**/.DS_Store": true,
        "**/__pycache__": true,
        "**/.mypy_cache": true,
        "**/.pytest_cache": true,
        "**/.ruff_cache": true,
        "**/.venv": true,
        "**/venv": true
    },
    "python.analysis.autoImportCompletions": true,
    "python.analysis.typeCheckingMode": "basic",
    "python.defaultInterpreterPath": "R:\\Users\\User\\miniconda3\\python.exe",
    "python-envs.terminal.autoActivationType": "shellStartup",
    "python.terminal.activateEnvironment": true,
    "python.testing.pytestEnabled": true,
    "python.testing.unittestEnabled": false,
    "python.testing.pytestArgs": [
        "."
    ],
    "search.exclude": {
        "**/.git": true,
        "**/node_modules": true,
        "**/dist": true,
        "**/build": true,
        "**/__pycache__": true,
        "**/.mypy_cache": true,
        "**/.pytest_cache": true,
        "**/.ruff_cache": true,
        "**/.venv": true,
        "**/venv": true
    },
    "chat.tools.terminal.autoApprove": {
        "R:\\Users\\User\\miniconda3\\python.exe": true,
        "/^python -c \"import sys; print\\(sys\\.executable\\)\"$/": {
            "approve": true,
            "matchCommandLine": true
        },
        "git checkout": true,
        "Test-Path": true,
        "&": true
    }
}
