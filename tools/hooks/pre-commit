#!/usr/bin/env bash
set -euo pipefail

if [ -x ".venv/Scripts/python.exe" ]; then
  ".venv/Scripts/python.exe" scripts/policy_check.py --stage pre-commit
elif command -v python >/dev/null 2>&1; then
  python scripts/policy_check.py --stage pre-commit
elif command -v py >/dev/null 2>&1; then
  py -3 scripts/policy_check.py --stage pre-commit
else
  echo "No Python interpreter found for policy check." >&2
  exit 1
fi
